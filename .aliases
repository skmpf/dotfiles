# ===== ENVIRONMENT =====
export EDITOR=vim

# ===== ESSENTIAL ALIASES =====

# Navigation
alias ls='eza --group-directories-first --icons'
alias l='ls -l'
alias ll='ls -la --git'
alias la='ls -a'
alias lt='ls --tree --level=2'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gf='git fetch -ap'
alias gpl='git pull'
alias gl='git l'
alias gd='git diff'
alias gb='git branch'
alias gco='git checkout'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias mkdir='mkdir -pv'

# Quick edits
alias aliases='$EDITOR ~/.aliases && source ~/.zshrc'
alias zshrc='$EDITOR ~/.zshrc && source ~/.zshrc'
alias reload='source ~/.zshrc'

# System
alias h='history'
alias j='jobs'
alias ports='lsof -i -P -n | grep LISTEN'

# Misc
alias c='clear'
alias path='echo -e ${PATH//:/\\n}'

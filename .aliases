# ===== ENVIRONMENT =====
export EDITOR=vim

# ===== ESSENTIAL ALIASES =====

# Navigation
alias ls='ls -G'
alias ll='ls -lah'
alias la='ls -a'
alias lt='ls -lhR'
alias l='ls -lh'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit -m'
alias gp='git push'
alias gf='git fetch -ap'
alias gpl='git pull'
alias gl='git l'
alias gd='git diff'
alias gb='git branch'
alias gco='git checkout'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias mkdir='mkdir -pv'

# Quick edits
alias aliases='$EDITOR ~/.aliases && source ~/.zshrc'
alias zshrc='$EDITOR ~/.zshrc && source ~/.zshrc'
alias reload='source ~/.zshrc'

# System
alias h='history'
alias j='jobs'
alias ports='lsof -i -P -n | grep LISTEN'

# Misc
alias c='clear'
alias path='echo -e ${PATH//:/\\n}'
alias oc='openclaw'
alias ocg='openclaw gateway'
alias ocgs='openclaw gateway status'
alias ocgr='openclaw gateway restart'
alias occv='openclaw config validate'
alias ocd='openclaw doctor --fix'
alias ocsf='openclaw security audit --deep'
alias gdoj="git -C ~/.openclaw show HEAD:openclaw.json | jq -S . > /tmp/openclaw-head.json && jq -S . ~/.openclaw/openclaw.json > /tmp/openclaw-worktree.json && diff --color=always -u /tmp/openclaw-head.json /tmp/openclaw-worktree.json"

# Bitwarden session helper (writes key where agent expects it)
alias bwsession='export BW_SESSION="$(bw unlock --raw)" && printf "%s" "$BW_SESSION" > /tmp/bw_session && chmod 600 /tmp/bw_session && echo "BW session saved: /tmp/bw_session"'
